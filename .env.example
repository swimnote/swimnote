# =============================================================
# 스윔노트 (SwimNote) 환경변수 예시
# 실제 값 없이 형식만 표시 — 절대 Git에 실제 값을 넣지 말 것
# 자세한 설명은 docs/ENVIRONMENT_SETUP.md 참고
# =============================================================

# ── DB 연결 ──────────────────────────────────────────────────
SUPABASE_DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_ID].supabase.co:5432/postgres
POOL_DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_ID2].supabase.co:5432/postgres
SUPER_PROTECT_DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_ID3].supabase.co:5432/postgres

# ── 인증 ─────────────────────────────────────────────────────
JWT_SECRET=your-very-long-random-secret-minimum-32-characters

# ── 파일 스토리지 (Replit Object Storage) ────────────────────
# ⚠️ Replit 전용 — 다른 환경 이관 시 R2/S3로 교체 필요
DEFAULT_OBJECT_STORAGE_BUCKET_ID=bucket-[ID]

# Cloudflare R2 (이관 시 사용)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY=
# R2_SECRET_KEY=
# R2_PHOTO_BUCKET=swimnote-photos
# R2_VIDEO_BUCKET=swimnote-videos

# ── SMS 발송 ─────────────────────────────────────────────────
SMS_PROVIDER=naver
NAVER_SENS_ACCESS_KEY=YOUR_NAVER_ACCESS_KEY
NAVER_SENS_SECRET_KEY=YOUR_NAVER_SECRET_KEY
NAVER_SENS_SENDER_PHONE=01012345678
NAVER_SENS_SERVICE_ID=ncp:sms:kr:XXXXXXXXXX:service-name
SMS_DEV_EXPOSE_CODE=true

# ── 결제 ─────────────────────────────────────────────────────
PAYMENT_PROVIDER=portone
PORTONE_API_SECRET=your_portone_api_secret
PORTONE_CHANNEL_KEY=channel-key-xxxxx
TOSS_SECRET_KEY=test_sk_xxxxxxxx

# ── 시스템 설정 ───────────────────────────────────────────────
NODE_ENV=production
PORT=8080
PHOTO_LIMIT_MB=10
VIDEO_LIMIT_MB=100
POOL_DB_LIMIT_MB=500
SUPER_DB_LIMIT_MB=1000

# ── 모바일 앱 (artifacts/swim-app/.env) ──────────────────────
EXPO_PUBLIC_API_URL=https://your-api-domain.com/api
EXPO_PUBLIC_DOMAIN=your-api-domain.com
