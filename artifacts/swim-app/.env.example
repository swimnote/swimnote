# SwimNote Expo App — 환경변수 예시
# 로컬 개발 시 이 파일을 .env로 복사 후 실제 값을 채우세요.
# cp .env.example .env

# API 서버 주소 (로컬 개발 시)
EXPO_PUBLIC_API_URL=http://localhost:8080/api
EXPO_PUBLIC_DOMAIN=localhost:8080

# RevenueCat 공개 API 키
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=appl_xxxxxxxxxxxxxxxxxxxxxxxx
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=goog_xxxxxxxxxxxxxxxxxxxxxxxx

# 프로덕션 값은 eas.json의 build.production.env 섹션에 설정됨
