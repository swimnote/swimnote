{
  "expo": {
    "name": "SwimNote",
    "slug": "swim-app",
    "version": "1.3.5",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "swim-app",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/swimnote-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.swimnote.app",
      "buildNumber": "94",
      "usesAppleSignIn": true,
      "entitlements": {
        "com.apple.developer.applesignin": [
          "Default"
        ]
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "SwimNote accesses your photo library to attach photos to class lesson diaries and progress reports. For example, a teacher can attach a photo from the gallery to document a student's swimming technique during a lesson.",
        "NSPhotoLibraryAddUsageDescription": "SwimNote saves photos to your photo library when you download lesson diary images or class photos shared by your swimming instructor.",
        "NSCameraUsageDescription": "SwimNote uses the camera to take photos directly for lesson diaries and class progress documentation. For example, a teacher can photograph a student's swimming form to include in the lesson record.",
        "LSApplicationQueriesSchemes": [
          "kakaokompassauth",
          "storekvstore",
          "kakaolink",
          "kakaotalk",
          "kakaostory",
          "kakaoplus",
          "kakaonavi",
          "kakaomail",
          "kakaoopen"
        ]
      }
    },
    "android": {
      "softwareKeyboardLayoutMode": "pan",
      "package": "com.swimnote.app",
      "versionCode": 117,
      "edgeToEdge": true,
      "allowBackup": false
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Pretendard-Regular.otf",
            "./assets/fonts/Pretendard-Medium.otf",
            "./assets/fonts/Pretendard-SemiBold.otf",
            "./assets/fonts/Pretendard-Bold.otf"
          ]
        }
      ],
      "expo-apple-authentication",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#1A5CFF"
        }
      ],
      [
        "@react-native-seoul/kakao-login",
        {
          "kakaoAppKey": "0c984af3a5fcb64715c2cf3cc76c55ca",
          "kotlinVersion": "2.0.21",
          "overrideKakaoSDKVersion": "2.22.0"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "7d0e0faa-32d8-4f40-88c4-2c99e0613afc"
      }
    },
    "owner": "swimnote"
  }
}
